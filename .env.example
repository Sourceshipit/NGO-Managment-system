# ═══════════════════════════════════════════════════════════════════
# Clarion — Environment Variables
# Copy this file to .env and fill in values for your environment
# ═══════════════════════════════════════════════════════════════════

# Secret key for JWT signing. MUST be changed in production.
SECRET_KEY=clarion-local-dev-secret-2025

# Comma-separated list of allowed CORS origins.
# In production, set this to your actual frontend domain(s).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Database connection URL. Default is SQLite (auto-created on startup).
DATABASE_URL=sqlite:///./clarion.db

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7
