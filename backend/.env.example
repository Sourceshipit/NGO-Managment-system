# ═══════════════════════════════════════════════════════════════════
# BeneTrack — Backend Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# Secret key for JWT signing. MUST be changed in production.
SECRET_KEY=change-me-to-a-random-string

# Database connection URL
# MySQL (production / recommended):
DATABASE_URL=mysql+pymysql://root:<password>@localhost/benetrack
# SQLite (quick local dev, no server needed):
# DATABASE_URL=sqlite:///./benetrack.db

# ── Google OAuth (optional — leave blank to disable) ──────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=

# ── Razorpay Payment Gateway ─────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use Test keys for development (rzp_test_...), Live keys for production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── CORS (comma-separated origins) ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Token Lifetimes ──────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
