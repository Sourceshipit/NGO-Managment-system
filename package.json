{
  "name": "clarion-root",
  "version": "1.0.0",
  "description": "Root orchestrator for Clarion",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd frontend && npm install && cd ../backend && pip install -r requirements.txt",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "server": "npm run dev:backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "shadcn": "^4.1.2"
  },
  "dependencies": {
    "gl-matrix": "^3.4.4",
    "gsap": "^3.14.2"
  }
}